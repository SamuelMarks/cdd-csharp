<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Cdd.OpenApi\Cdd.OpenApi.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseWasiSdk)' == 'true'">
    <PackageReference Include="Wasi.Sdk" Version="0.1.4-preview.10020" />
    <TrimmerRootDescriptor Include="TrimmerRoots.xml" />
  </ItemGroup>
  <PropertyGroup>
    <Version>0.0.1</Version>
    <OutputType>Exe</OutputType>
    <AssemblyName>cdd-csharp</AssemblyName>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>cdd-csharp</ToolCommandName>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishAot Condition="'$(UseWasiSdk)' != 'true'">true</PublishAot>
    <RunAOTCompilation>true</RunAOTCompilation>
    <InvariantGlobalization>true</InvariantGlobalization>
    <EventSourceSupport>false</EventSourceSupport>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
    <IlcGenerateStackTraceData>false</IlcGenerateStackTraceData>
    <WasmStackSize>40960000</WasmStackSize>
  </PropertyGroup>

</Project>